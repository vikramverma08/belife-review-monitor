rules_version = '2';

// Security model:
//   - Cloud Functions write everything via the Admin SDK, which BYPASSES
//     these rules. So clients never need write access for the poll pipeline.
//   - The dashboard (public/index.html) reads Firestore directly from the
//     browser, so it needs READ access.
//
// Reviews are public Google data, but the branch list / alerts are internal,
// so by default we still gate reads behind Firebase Authentication. If you
// want a fully public read-only dashboard, replace `request.auth != null`
// with `true` — but then anyone with your Firebase config can read the data.
service cloud.firestore {
  match /databases/{database}/documents {

    match /branches/{branchId} {
      allow read: if request.auth != null;
      allow write: if false; // only the Admin SDK (Cloud Functions) writes

      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /alerts/{alertId} {
      allow read: if request.auth != null;
      // Let signed-in staff resolve/dismiss alerts (status field only).
      allow update: if request.auth != null;
      allow create, delete: if false;
    }
  }
}
